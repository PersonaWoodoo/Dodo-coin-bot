def parse_amount(text):
    text = str(text).lower().replace(' ', '').replace(',', '.')
    if 'к' in text:
        try:
            number = float(text.replace('к', ''))
            return int(number * 1000)
        except:
            return None
    else:
        try:
            return int(float(text))
        except:
            return None

def calculate_win_rate(user):
    if user['games_played'] == 0:
        return 0
    return round((user['games_won'] / user['games_played']) * 100, 1)

# =========== ИГРА MINES (×1.25 за клетку) ===========
class MinesGame:
    def __init__(self, user_id, bet, mines_count):
        self.user_id = str(user_id)
        self.bet = bet
        self.mines_count = mines_count
        self.grid_size = 6
        self.grid = [['⬜' for _ in range(self.grid_size)] for _ in range(self.grid_size)]
        self.mines_positions = set()
        self.opened_cells = set()
        self.multiplier = 1.0
        self.game_active = True
        self.won = False
        self.generate_mines()
    
    def generate_mines(self):
        all_cells = list(range(self.grid_size * self.grid_size))
        self.mines_positions = set(random.sample(all_cells, self.mines_count))
    
    def open_cell(self, cell_index):
        if cell_index in self.opened_cells or not self.game_active:
            return None, None
        
        self.opened_cells.add(cell_index)
        row = cell_index // self.grid_size
        col = cell_index % self.grid_size
        
        if cell_index in self.mines_positions:
            self.game_active = False
            self.won = False
            self.grid[row][col] = '💣'
            return 'mine', 0.0
        else:
            self.multiplier *= 1.25
            self.grid[row][col] = f'🟩{self.multiplier:.2f}x'
            total_safe = self.grid_size * self.grid_size - self.mines_count
            if len(self.opened_cells) == total_safe:
                self.game_active = False
                self.won = True
                return 'win', self.multiplier
            return 'safe', self.multiplier
    
    def cash_out(self):
        if not self.game_active:
            return 0
        self.game_active = False
        self.won = True
        return int(self.bet * self.multiplier)
    
    def get_grid_display(self):
        display = "🎮 *МИНЫ*\n"
        display += "```\n"
        for i in range(self.grid_size):
            for j in range(self.grid_size):
                cell = i * self.grid_size + j
                if cell in self.opened_cells:
                    if cell in self.mines_positions:
                        display += "💣 "
                    else:
                        display += f"{self.multiplier:.2f}x".ljust(4) if cell == list(self.opened_cells)[-1] else "✅  "
                else:
                    display += f"[{cell+1:02d}] "
            display += "\n"
        display += "```\n"
        display += f"💣 Мин: {self.mines_count}\n"
        display += f"💰 Ставка: {self.bet} Dcoin\n"
        display += f"📈 Текущий множитель: x{self.multiplier:.2f}\n"
        display += f"💵 Текущий выигрыш: {int(self.bet * self.multiplier)} Dcoin"
        return display

