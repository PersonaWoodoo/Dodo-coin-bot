def process_mines_bet(message):
    try:
        bet = parse_amount(message.text)
        if not bet or bet < 100:
            bot.send_message(message.chat.id, "❌ Минимальная ставка: 100 Dcoin")
            bot.register_next_step_handler(message, process_mines_bet)
            return
        
        user = init_user(message.from_user.id)
        if user['balance'] < bet:
            bot.send_message(message.chat.id, "❌ Недостаточно средств")
            return
        
        ctx = get_user_context(message.from_user.id)
        ctx['mines_bet'] = bet
        
        bot.send_message(
            message.chat.id,
            f"✅ Ставка принята: {bet} Dcoin\n\n"
            "💣 Введите количество мин (1-6):"
        )
        bot.register_next_step_handler(message, process_mines_count)
    except Exception as e:
        bot.send_message(message.chat.id, f"❌ Ошибка: {e}")

def process_mines_count(message):
    try:
        mines = int(message.text.strip())
        if mines < 1 or mines > 6:
            bot.send_message(message.chat.id, "❌ Количество мин должно быть от 1 до 6!")
            bot.register_next_step_handler(message, process_mines_count)
            return
        
        user_id = message.from_user.id
        ctx = get_user_context(user_id)
        bet = ctx.get('mines_bet')
        if not bet:
            bot.send_message(message.chat.id, "❌ Ошибка ставки. Начните заново.")
            return
        
        # Списываем баланс и учитываем оборот
        user = init_user(user_id)
        user['balance'] -= bet
        user['turnover'] += bet
        data = load_data()
        data[str(user_id)] = user
        save_data(data)
        
        game = MinesGame(user_id, bet, mines)
        active_mines_games[str(user_id)] = game
        
        show_mines_field(message, game)
    except ValueError:
        bot.send_message(message.chat.id, "❌ Введите число от 1 до 6!")
        bot.register_next_step_handler(message, process_mines_count)

def show_mines_field(message, game):
    markup = types.InlineKeyboardMarkup(row_width=6)
    for i in range(6):
        row = []
        for j in range(6):
            cell = i * 6 + j
            if cell in game.opened_cells:
                if cell in game.mines_positions:
                    row.append(types.InlineKeyboardButton('💣', callback_data=f'mines_cell_{cell}'))
                else:
                    row.append(types.InlineKeyboardButton('✅', callback_data=f'mines_cell_{cell}'))
            else:
                row.append(types.InlineKeyboardButton(f'{cell+1:02d}', callback_data=f'mines_cell_{cell}'))
        markup.row(*row)
    
    markup.row(
        types.InlineKeyboardButton(f'💰 Забрать x{game.multiplier:.2f}', callback_data='mines_cashout'),
        types.InlineKeyboardButton('❌ Выйти', callback_data='mines_cancel')
    )
    
    bot.send_message(
        message.chat.id,
        game.get_grid_display(),
        reply_markup=markup,
        parse_mode='Markdown'
    )

