# =========== ИГРА КРАШ (ИСПРАВЛЕННАЯ) ===========
def get_crash_multiplier():
    r = random.random()
    if r < 0.0001:
        return round(random.uniform(1000, 100000), 2)
    elif r < 0.001:
        return round(random.uniform(100, 1000), 2)
    elif r < 0.01:
        return round(random.uniform(10, 100), 2)
    elif r < 0.1:
        return round(random.uniform(5, 10), 2)
    else:
        return round(random.uniform(1.01, 5), 2)

