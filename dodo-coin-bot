                f"💰 Баланс: {user['balance']} Dcoin",
                chat_id=call.message.chat.id,
                message_id=call.message.message_id,
                parse_mode='Markdown'
            )
        except Exception as e:
            print(f"Ошибка при редактировании сообщения: {e}")
            bot.send_message(
                call.message.chat.id,
                f"✈️ *ВЫ ЗАБРАЛИ!*\n\n"
                f"💰 Ставка: {bet} Dcoin\n"
                f"📈 Множитель: x{current_multi:.2f}\n"
                f"💵 Выигрыш: +{win} Dcoin\n"
                f"💰 Баланс: {user['balance']} Dcoin",
                parse_mode='Markdown'
            )
        
        # Удаляем игру
        del active_crash_games[game_id]
        
        bot.answer_callback_query(call.id, "✅ Вы забрали выигрыш!")
        
    except Exception as e:
