                    (message.text.lower().startswith('дать') or 
                     message.text.lower().startswith('перевести') or 
                     message.text.lower().startswith('накинуть') or 
                     message.text.lower().startswith('/give')))
@subscription_required
@ban_required
def transfer_reply(message):
    try:
        text = message.text.strip()
        if text.lower().startswith('/give'):
            text = text[5:].strip()
        else:
            parts = text.split()
            if len(parts) >= 2:
                text = ' '.join(parts[1:])
        
        amount = parse_amount(text)
        if not amount or amount < 100:
            bot.send_message(message.chat.id, "❌ Минимальная сумма перевода: 100 Dcoin")
            return
        
        sender = init_user(message.from_user.id)
        if sender['balance'] < amount:
            bot.send_message(message.chat.id, "❌ Недостаточно средств")
            return
        
        target_user = message.reply_to_message.from_user
        if target_user.id == message.from_user.id:
            bot.send_message(message.chat.id, "❌ Нельзя переводить самому себе")
            return
        
        target = init_user(target_user.id)
        
        sender['balance'] -= amount
        target['balance'] += amount
        
        data = load_data()
        data[str(message.from_user.id)] = sender
        data[str(target_user.id)] = target
        save_data(data)
        
        bot.send_message(
            message.chat.id,
            f"✅ *Перевод выполнен!*\n\n"
            f"Получатель: {target_user.first_name}\n"
            f"Сумма: *{amount} Dcoin*\n"
            f"Ваш баланс: {sender['balance']} Dcoin",
            parse_mode='Markdown'
        )
        
        try:
            bot.send_message(
                target_user.id,
                f"💰 *Вам перевели Dcoin!*\n"
                f"От: {message.from_user.first_name}\n"
                f"Сумма: +{amount} Dcoin\n"
                f"Баланс: {target['balance']} Dcoin",
                parse_mode='Markdown'
            )
        except:
            pass
            
    except Exception as e:
        bot.send_message(message.chat.id, f"❌ Ошибка: {e}")

