            message_id=call.message.message_id,
            parse_mode='Markdown'
        )
        return
    
    text = "🚫 *ЗАБЛОКИРОВАННЫЕ ПОЛЬЗОВАТЕЛИ:*\n\n"
    for user_id, ban_info in banned.items():
        ban_until = datetime.fromisoformat(ban_info['until'])
        days_left = (ban_until - datetime.now()).days
        text += f"🆔 `{user_id}`\n"
        text += f"📅 До: {ban_until.strftime('%d.%m.%Y')}\n"
        text += f"⏳ Осталось: {days_left} дн.\n"
        text += f"📝 Причина: {ban_info.get('reason', 'Не указана')}\n\n"
    
    bot.edit_message_text(
        text,
        chat_id=call.message.chat.id,
        message_id=call.message.message_id,
        parse_mode='Markdown'
    )

