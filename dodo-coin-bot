        user['games_won'] += 1
        user['turnover'] += win
        
        if win > bet * 10:
            user['dmp'] += int(win * 0.01)
        
        data = load_data()
        data[user_id] = user
        save_data(data)
        
        try:
            bot.edit_message_text(
