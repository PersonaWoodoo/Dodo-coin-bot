        current = 1.0
        step = 0.05
        
        for i in range(100):
            if game_id not in active_crash_games or not active_crash_games[game_id]['active']:
                break
                
            if current >= crash_point:
                try:
                    # Проверяем, не забрали ли уже
                    if game_id in active_crash_games and active_crash_games[game_id]['active']:
                        bot.edit_message_text(
                            f"✈️ *КРАШ!*\n\n"
                            f"💰 Ставка: {bet} Dcoin\n"
                            f"💥 Краш на: x{crash_point}\n"
                            f"❌ *ПРОИГРЫШ*\n"
                            f"💸 Потеряно: -{bet} Dcoin",
                            chat_id=call.message.chat.id,
                            message_id=call.message.message_id,
                            parse_mode='Markdown'
                        )
                        user = init_user(user_id)
                        user['lost_total'] += bet
                        add_to_admin(bet)
                        data = load_data()
                        data[user_id] = user
                        save_data(data)
                        
                        if game_id in active_crash_games:
                            del active_crash_games[game_id]
                except Exception as e:
                    print(f"Ошибка при краше: {e}")
                break
            
            if i % 2 == 0:
                try:
                    if game_id in active_crash_games and active_crash_games[game_id]['active']:
                        active_crash_games[game_id]['current_multiplier'] = current
                        bot.edit_message_text(
                            f"✈️ *Краш летит...*\n\n"
                            f"💰 Ставка: {bet} Dcoin\n"
                            f"📈 Текущий: x{current:.2f}",
                            chat_id=call.message.chat.id,
                            message_id=call.message.message_id,
                            reply_markup=markup,
                            parse_mode='Markdown'
                        )
                except Exception as e:
                    print(f"Ошибка при обновлении: {e}")
                    break
            
            current += step * random.uniform(0.8, 1.2)
            time.sleep(0.1)
    
    thread = threading.Thread(target=animate_crash)
    thread.daemon = True
    thread.start()

@bot.callback_query_handler(func=lambda call: call.data.startswith('crash_take_'))
def crash_take(call):
    try:
        game_id = call.data.replace('crash_take_', '')
        
        if game_id not in active_crash_games:
            bot.answer_callback_query(call.id, "❌ Игра не найдена или уже завершена!", show_alert=True)
