        return
    
    try:
        parts = message.text.split()
        if len(parts) < 4:
            bot.send_message(message.chat.id, "❌ Формат: `/ban ID ДНИ ПРИЧИНА`", parse_mode='Markdown')
            return
        
        user_id = parts[1]
        days = int(parts[2])
        reason = ' '.join(parts[3:])
        
        banned = load_banned()
        ban_until = datetime.now() + timedelta(days=days)
        
        banned[user_id] = {
            'until': ban_until.isoformat(),
            'reason': reason,
            'banned_by': ADMIN_ID,
            'banned_at': datetime.now().isoformat()
        }
        save_banned(banned)
        
        try:
            bot.send_message(
                user_id,
                f"🚫 *Вы заблокированы!*\n\n"
                f"📅 До: {ban_until.strftime('%d.%m.%Y %H:%M')}\n"
                f"⏳ Дней: {days}\n"
                f"📝 Причина: {reason}",
                parse_mode='Markdown'
            )
        except:
            pass
        
        bot.send_message(
            message.chat.id,
            f"✅ *Пользователь заблокирован!*\n\n"
            f"🆔 ID: `{user_id}`\n"
            f"⏳ Срок: {days} дней\n"
