def subscription_required(func):
    def wrapper(message, *args, **kwargs):
        # Пропускаем без проверки подписок
        return func(message, *args, **kwargs)
    return wrapper

def is_banned(user_id):
    banned = load_banned()
    user_id = str(user_id)
    if user_id in banned:
        ban_info = banned[user_id]
        if ban_info['until']:
            ban_until = datetime.fromisoformat(ban_info['until'])
            if datetime.now() < ban_until:
                return True, ban_info
            else:
                del banned[user_id]
                save_banned(banned)
    return False, None

def ban_required(func):
    def wrapper(message, *args, **kwargs):
        user_id = message.from_user.id
        banned, ban_info = is_banned(user_id)
        if banned:
            ban_until = datetime.fromisoformat(ban_info['until'])
            days_left = (ban_until - datetime.now()).days
            reason = ban_info.get('reason', 'Не указана')
            bot.send_message(
                message.chat.id,
                f"🚫 *Вы забанены!*\n\n"
                f"📅 До: {ban_until.strftime('%d.%m.%Y %H:%M')}\n"
                f"⏳ Осталось дней: {days_left}\n"
                f"📝 Причина: {reason}",
                parse_mode='Markdown'
            )
            return
        return func(message, *args, **kwargs)
    return wrapper

